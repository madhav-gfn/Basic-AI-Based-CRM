# Port the Channel service listens on. Render injects its own PORT in production.
PORT=3004

# Where to POST simulated (or provider-normalized) delivery webhooks back to.
CRM_RECEIPT_URL=http://localhost:3001/api/webhooks/receipt

# ── Provider selection ───────────────────────────────────────────────────────
# One of "simulator" (default, no credentials needed) or a real provider name.
# Leave unset / "simulator" until you have paying-client budget for real sends.
EMAIL_PROVIDER=simulator
SMS_PROVIDER=simulator
WHATSAPP_PROVIDER=simulator

# ── Resend (EMAIL_PROVIDER=resend) ───────────────────────────────────────────
# RESEND_API_KEY=
# RESEND_FROM=

# ── Twilio (SMS_PROVIDER=twilio / WHATSAPP_PROVIDER=twilio) ─────────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=
# TWILIO_WHATSAPP_FROM=
