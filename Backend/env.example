# ── Database ──────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/xeno_crm"

# ── CRM API ───────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Channel Service ───────────────────────────────────────────────
CHANNEL_SERVICE_PORT=3002
CHANNEL_SERVICE_URL=http://localhost:3002

# ── CRM callback URL (used by channel-service to call back) ───────
CRM_RECEIPT_URL=http://localhost:3001/api/webhooks/receipt

# ── AI (Anthropic) ────────────────────────────────────────────────
GEMINI_API_KEY=your_key_here
GEMINI_MODEL=gemini-2.5-flash