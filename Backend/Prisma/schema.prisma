// packages/db/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// CUSTOMER
// ─────────────────────────────────────────────
model Customer {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  phone      String?
  gender     String?
  city       String?
  signupDate DateTime @default(now()) @map("signup_date")

  // ── Consent & deliverability (DPDP Act / GDPR compliance) ──────────────
  // A marketing CRM must honour opt-out. Suppressed customers are excluded
  // from all campaign dispatch. The token backs a public one-click
  // unsubscribe link embedded in outbound messages.
  consentStatus    ConsentStatus @default(OPTED_IN) @map("consent_status")
  unsubscribedAt   DateTime?     @map("unsubscribed_at")
  unsubscribeToken String        @unique @default(uuid()) @map("unsubscribe_token")

  // Free-form segmentation aids: tags for manual grouping, attributes for
  // arbitrary custom fields imported per brand (loyalty tier, birthday, …).
  tags       String[] @default([])
  attributes Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Tenancy (nullable for backward-compatible backfill onto existing rows).
  organizationId String? @map("organization_id")

  // Relations
  organization       Organization?       @relation(fields: [organizationId], references: [id])
  orders             Order[]
  communications     Communication[]
  journeyEnrollments JourneyEnrollment[]

  @@index([city])
  @@index([gender])
  @@index([consentStatus])
  @@index([organizationId])
  @@map("customers")
}

// ─────────────────────────────────────────────
// ORDER
// ─────────────────────────────────────────────
model Order {
  id         String   @id @default(uuid())
  customerId String   @map("customer_id")
  orderDate  DateTime @default(now()) @map("order_date")
  orderValue Float    @map("order_value")
  category   String

  // Relations
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  // Hot-path indexes: segment aggregation groups by customerId and filters
  // by orderDate/category on nearly every query.
  @@index([customerId])
  @@index([orderDate])
  @@index([category])
  @@map("orders")
}

// ─────────────────────────────────────────────
// SEGMENT
// ─────────────────────────────────────────────
model Segment {
  id         String   @id @default(uuid())
  name       String
  definition Json // e.g. { "rules": [{ "field": "city", "op": "eq", "value": "Delhi" }] }
  createdBy  String   @map("created_by")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  organizationId String? @map("organization_id")

  // Relations
  organization Organization? @relation(fields: [organizationId], references: [id])
  campaigns    Campaign[]
  journeys     Journey[]

  @@index([organizationId])
  @@map("segments")
}

// ─────────────────────────────────────────────
// CAMPAIGN
// ─────────────────────────────────────────────
model Campaign {
  id          String         @id @default(uuid())
  name        String
  audienceId  String         @map("audience_id")
  channel     Channel
  objective   String?
  status      CampaignStatus @default(DRAFT)
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  launchedAt  DateTime?      @map("launched_at")
  scheduledAt DateTime?      @map("scheduled_at")
  message     String?

  // Cached post-campaign AI insights — generated once on completion instead
  // of re-calling Gemini on every analytics page load.
  insights Json?

  organizationId String? @map("organization_id")

  // Relations
  organization   Organization?     @relation(fields: [organizationId], references: [id])
  audience       Segment           @relation(fields: [audienceId], references: [id])
  communications Communication[]
  variants       CampaignVariant[]

  @@index([status])
  @@index([scheduledAt])
  @@index([audienceId])
  @@index([organizationId])
  @@map("campaigns")
}

// ─────────────────────────────────────────────
// COMMUNICATION  (one per customer per campaign)
// ─────────────────────────────────────────────
model Communication {
  id            String              @id @default(uuid())
  // Exactly one of campaignId / journeyStepId is set — a Communication
  // originates from either a one-off Campaign blast or a Journey step send.
  // Enforced in application code (see JourneyService / ExecutionService);
  // both are nullable so the two send paths can share this single tracking
  // table (and therefore the whole webhook/analytics/activity pipeline).
  campaignId    String?             @map("campaign_id")
  journeyStepId String?             @map("journey_step_id")
  customerId    String              @map("customer_id")
  channel       Channel
  message       String // rendered personalised message
  status        CommunicationStatus @default(PENDING)
  scheduledAt   DateTime?
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  // A/B testing: which campaign variant this recipient was assigned (if any).
  variantId String? @map("variant_id")

  // Relations
  campaign    Campaign?            @relation(fields: [campaignId], references: [id])
  journeyStep JourneyStep?         @relation(fields: [journeyStepId], references: [id])
  customer    Customer             @relation(fields: [customerId], references: [id])
  variant     CampaignVariant?     @relation(fields: [variantId], references: [id])
  events      CommunicationEvent[]

  // NULLs are distinct in Postgres, so this only dedupes real campaign sends;
  // journey dedupe is enforced at the enrollment level instead.
  @@unique([campaignId, customerId])
  @@index([status])
  @@index([customerId])
  @@index([variantId])
  @@index([journeyStepId])
  @@map("communications")
}

// ─────────────────────────────────────────────
// COMMUNICATION EVENT  (lifecycle callbacks)
// ─────────────────────────────────────────────
model CommunicationEvent {
  id              String    @id @default(uuid())
  // First-class idempotency key from the channel service. A unique constraint
  // makes duplicate delivery of the same webhook a no-op at the DB level —
  // replacing the previous fragile ±10s timestamp-window heuristic.
  eventId         String    @unique @default(uuid()) @map("event_id")
  communicationId String    @map("communication_id")
  eventType       EventType
  timestamp       DateTime  @default(now())
  metadata        Json? // optional: link clicked, error reason, etc.

  // Relations
  communication Communication @relation(fields: [communicationId], references: [id])

  @@index([communicationId])
  @@index([eventType])
  @@map("communication_events")
}

// ─────────────────────────────────────────────
// MESSAGE TEMPLATE  (reusable campaign copy)
// ─────────────────────────────────────────────
model MessageTemplate {
  id          String   @id @default(uuid())
  name        String
  channel     Channel
  body        String // may contain {name}, {city}, {email} tokens
  description String?
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  organizationId String?       @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@index([channel])
  @@index([organizationId])
  @@map("message_templates")
}

// ─────────────────────────────────────────────
// ORGANIZATION & USER  (multi-tenancy + auth)
// ─────────────────────────────────────────────
model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users            User[]
  customers        Customer[]
  segments         Segment[]
  campaigns        Campaign[]
  messageTemplates MessageTemplate[]
  journeys         Journey[]

  @@map("organizations")
}

model User {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  email          String   @unique
  name           String
  passwordHash   String   @map("password_hash")
  role           UserRole @default(MEMBER)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("users")
}

// ─────────────────────────────────────────────
// CAMPAIGN VARIANT  (A/B testing)
// ─────────────────────────────────────────────
model CampaignVariant {
  id         String @id @default(uuid())
  campaignId String @map("campaign_id")
  label      String // "A", "B", "Control", …
  message    String
  weight     Int    @default(1) // relative allocation weight

  campaign       Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  communications Communication[]

  @@index([campaignId])
  @@map("campaign_variants")
}

// ─────────────────────────────────────────────
// JOURNEY  (trigger-based multi-step automation)
// ─────────────────────────────────────────────
//
// A Journey enrolls customers automatically (no marketer hits "send") when a
// trigger condition is met, then walks each enrollee through an ordered list
// of JourneySteps, waiting `delayHours` between each. This is deliberately
// built on the same primitives as one-off Campaigns — Communication rows,
// the same channel dispatch, the same webhook/analytics pipeline — so a
// journey-originated message is indistinguishable in reporting from a
// campaign-originated one except for its `journeyStepId`.
model Journey {
  id          String             @id @default(uuid())
  name        String
  status      JourneyStatus      @default(DRAFT)
  triggerType JourneyTriggerType @map("trigger_type")

  // Required when triggerType = SEGMENT_ENTRY; the journey enrolls each
  // customer who currently matches this segment's definition (evaluated on
  // every scan — see JourneyService for the "first-seen-only" semantics).
  triggerSegmentId String? @map("trigger_segment_id")

  // Watermark for trigger evaluation — CUSTOMER_CREATED / ORDER_PLACED scans
  // only consider rows created after this timestamp, so re-running a scan
  // never double-enrolls.
  lastScanAt DateTime? @map("last_scan_at")

  organizationId String?  @map("organization_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization   Organization?       @relation(fields: [organizationId], references: [id])
  triggerSegment Segment?            @relation(fields: [triggerSegmentId], references: [id])
  steps          JourneyStep[]
  enrollments    JourneyEnrollment[]

  @@index([status])
  @@index([triggerSegmentId])
  @@index([organizationId])
  @@map("journeys")
}

model JourneyStep {
  id         String  @id @default(uuid())
  journeyId  String  @map("journey_id")
  // 0-based order within the journey. Enforced unique per journey in
  // application code (Prisma doesn't support composite ordering constraints
  // cleanly here without extra migration ceremony this project doesn't use).
  order      Int
  // Hours to wait after the previous step (or after enrollment, for step 0)
  // before sending this one.
  delayHours Int     @default(0) @map("delay_hours")
  channel    Channel
  message    String // may contain {name}, {city}, {email} tokens

  journey        Journey         @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  communications Communication[]

  @@index([journeyId])
  @@map("journey_steps")
}

model JourneyEnrollment {
  id         String           @id @default(uuid())
  journeyId  String           @map("journey_id")
  customerId String           @map("customer_id")
  status     EnrollmentStatus @default(ACTIVE)

  // Index into the journey's ordered steps of the NEXT step to send.
  currentStepIndex Int       @default(0) @map("current_step_index")
  // When the next step becomes eligible to send. Null once COMPLETED/EXITED.
  nextStepDueAt    DateTime? @map("next_step_due_at")

  enrolledAt  DateTime  @default(now()) @map("enrolled_at")
  completedAt DateTime? @map("completed_at")
  exitedAt    DateTime? @map("exited_at")

  journey  Journey  @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  // A customer may only have one ACTIVE run through a given journey at a
  // time; app logic allows re-enrollment after COMPLETED/EXITED rather than
  // enforcing that here (Prisma unique constraints can't be conditional).
  @@index([journeyId, status])
  @@index([customerId])
  @@index([nextStepDueAt])
  @@map("journey_enrollments")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────
enum Channel {
  WHATSAPP
  SMS
  EMAIL
  RCS
}

enum ConsentStatus {
  OPTED_IN
  OPTED_OUT
  UNKNOWN
}

enum UserRole {
  ADMIN
  MEMBER
}

enum JourneyStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum JourneyTriggerType {
  CUSTOMER_CREATED
  ORDER_PLACED
  SEGMENT_ENTRY
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  EXITED
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  COMPLETED
  FAILED
}

enum CommunicationStatus {
  PENDING
  SENT
  DELIVERED
  OPENED
  READ
  CLICKED
  FAILED
}

enum EventType {
  SENT
  DELIVERED
  OPENED
  READ
  CLICKED
  CONVERTED // order placed because of this comms
  FAILED
}
