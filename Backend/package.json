{
  "name": "backend",
  "version": "1.0.0",
  "main": "dist/index.js",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "postinstall": "node -e \"try{require('debug')}catch(e){console.log('debug broken, reinstalling...');require('child_process').execSync('npm install debug@4.4.0 --no-save',{stdio:'inherit'})}\"",
    "db:seed": "ts-node Prisma/seed.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push"
  },
  "license": "ISC",
  "dependencies": {
    "@google/genai": "^2.8.0",
    "@prisma/client": "^6.0.0",
    "cors": "^2.8.6",
    "csv-parser": "^3.2.1",
    "debug": "4.4.0",
    "dotenv": "^16.0.0",
    "express": "^4.21.2",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "openai": "^6.45.0"
  },
  "overrides": {
    "debug": "4.4.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.11",
    "prisma": "^6.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  }
}
